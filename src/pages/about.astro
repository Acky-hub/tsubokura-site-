---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="坪倉秀行のプロフィール・経歴・メッセージ">
  <!-- Hero -->
  <section class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center fade-in">
        <div class="relative">
          <div class="aspect-[3/4] overflow-hidden bg-[#141414] rounded-sm">
            <img src="/images/hero.jpg" alt="坪倉秀行" class="w-full h-full object-cover mix-blend-luminosity opacity-90" />
            <div class="absolute inset-0 bg-[#141414]/15"></div>
          </div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 border border-accent opacity-30"></div>
        </div>
        <div>
          <p class="text-accent text-sm tracking-[0.3em] uppercase mb-4">About</p>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">坪倉秀行</h1>
          <p class="text-accent text-lg mb-6">株式会社ヴィクトワール 代表取締役</p>
          <div class="gold-line w-12 mb-8"></div>
          <p class="text-text-sub leading-relaxed">
            岡山を拠点に、飲食・美容・サウナ事業を多角的に展開。
            「食」「美」「癒し」の3領域で、地域に求められるサービスを追求しています。
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gold-line max-w-5xl mx-auto"></div>

  <!-- Philosophy -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center fade-in">
      <p class="text-accent text-sm tracking-[0.3em] uppercase mb-8">Philosophy</p>
      <h2 class="text-2xl md:text-3xl font-bold leading-relaxed mb-8">
        「地域とともに成長する」
      </h2>
      <p class="text-text-sub leading-relaxed">
        一つの事業に閉じず、飲食・美容・ウェルネスと領域を広げながら、
        それぞれの事業で地域に本当に必要とされるサービスを創り続ける。
        ヴィクトワールが目指すのは、事業を通じた地域社会への貢献と、
        関わるすべての人の生活を豊かにすること。
      </p>
    </div>
  </section>

  <div class="gold-line max-w-5xl mx-auto"></div>

  <!-- Career -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 fade-in">
      <p class="text-accent text-sm tracking-[0.3em] uppercase mb-8 text-center">Career</p>
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center">経歴</h2>
      <div class="space-y-8 border-l border-border pl-8">
        <div class="relative">
          <div class="absolute -left-[33px] w-2 h-2 rounded-full bg-accent mt-2"></div>
          <p class="text-text-sub text-sm mb-1">※ 年次情報をここに記載</p>
          <p class="font-bold">株式会社ヴィクトワール 設立</p>
        </div>
        <div class="relative">
          <div class="absolute -left-[33px] w-2 h-2 rounded-full bg-accent mt-2"></div>
          <p class="font-bold">定食酒場 にこ家 開業</p>
          <p class="text-text-sub text-sm mt-1">岡山市北区奥田</p>
        </div>
        <div class="relative">
          <div class="absolute -left-[33px] w-2 h-2 rounded-full bg-accent mt-2"></div>
          <p class="font-bold">Labradorite（美容サロン）開業</p>
        </div>
        <div class="relative">
          <div class="absolute -left-[33px] w-2 h-2 rounded-full bg-accent mt-2"></div>
          <p class="font-bold">DD SAUNA 開業</p>
        </div>
      </div>
    </div>
  </section>

  <div class="gold-line max-w-5xl mx-auto"></div>

  <!-- Message -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center fade-in">
      <p class="text-accent text-sm tracking-[0.3em] uppercase mb-8">Message</p>
      <h2 class="text-2xl md:text-3xl font-bold mb-8">代表メッセージ</h2>
      <blockquote class="text-text-sub text-lg leading-relaxed italic">
        「地域の皆様に支えられ、今日のヴィクトワールがあります。<br />
        これからも新しい挑戦を続け、<br class="hidden md:block" />
        岡山から新たな価値を発信してまいります。」
      </blockquote>
      <p class="text-accent mt-8">坪倉秀行</p>
    </div>
  </section>
</BaseLayout>
