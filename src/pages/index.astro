---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import StatsSection from '../components/StatsSection.astro';
import PhilosophySection from '../components/PhilosophySection.astro';
import AboutPreview from '../components/AboutPreview.astro';
import BusinessCard from '../components/BusinessCard.astro';
import BlogCard from '../components/BlogCard.astro';
import ChannelSection from '../components/ChannelSection.astro';
import RecruitSection from '../components/RecruitSection.astro';
import { getBlogs, getBusinessList } from '../lib/microcms';

let blogs = { contents: [] as any[] };
let businesses = { contents: [] as any[] };

try { blogs = await getBlogs(3); } catch {}
try { businesses = await getBusinessList(); } catch {}

const fallbackBusinesses = [
  {
    name: '定食酒場 にこ家',
    description: '岡山市北区。地域に愛される心のこもった家庭料理。',
    category: 'Food & Dining',
    image: '/images/nikoya.jpg',
    url: 'https://tabelog.com/okayama/A3301/A330101/33017934/',
  },
  {
    name: 'Labradorite',
    description: '大阪・岡山。マツエク・リラクゼーション・ホットストーン。',
    category: 'Beauty',
    image: '/images/labradorite.jpg',
    url: 'https://beauty.hotpepper.jp/kr/slnH000481641/',
  },
  {
    name: 'DD SAUNA',
    description: '岡山市北区。完全個室の大型プライベートラグジュアリーサウナ。',
    category: 'Wellness',
    image: '/images/dd-sauna-pro.jpg',
    url: 'https://the-dd-sauna.com/',
  },
  {
    name: 'AROMA TRUFFLE',
    description: '福岡・岩田屋本店。トリュフ香るグルメブランド。',
    category: 'Food & Gourmet',
    image: '/images/aroma-truffle.webp',
    url: 'https://aromatruffle.jp/',
  },
  {
    name: '株式会社ヴィクトワール',
    description: '飲食・美容・サウナ事業を多角的に展開する総合企業。',
    category: 'Corporate',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&q=80',
    url: 'https://victoire-corp.com/',
  },
];

const bizItems = businesses.contents.length > 0 ? businesses.contents : fallbackBusinesses;
---
<BaseLayout title="公式サイト" fullWidth={true}>
  <HeroSection />

  <StatsSection />

  <AboutPreview />

  <PhilosophySection />

  <!-- Business Section -->
  <section class="py-24 md:py-40 relative" id="business">
    <!-- Large scrolling background text -->
    <div class="overflow-hidden mb-16 md:mb-24">
      <div class="whitespace-nowrap" data-scroll-x>
        <span class="text-[8rem] md:text-[12rem] lg:text-[16rem] font-serif text-outline tracking-wider">
          BUSINESS&nbsp;&nbsp;&nbsp;BUSINESS&nbsp;&nbsp;&nbsp;BUSINESS
        </span>
      </div>
    </div>

    <div class="metallic-line mb-16 md:mb-24"></div>

    <!-- Business Cards -->
    <div class="flex flex-col gap-0">
      {bizItems.map((biz, i) => (
        <BusinessCard
          name={biz.name}
          description={biz.description}
          category={biz.category}
          image={biz.image}
          url={biz.url}
          index={i}
        />
      ))}
    </div>
  </section>

  <!-- Blog -->
  {blogs.contents.length > 0 && (
    <section class="py-28 border-t border-border/30">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-16 gsap-fade-up">
          <p class="section-label mb-4">Blog</p>
          <h2 class="heading-serif text-3xl md:text-4xl">最新の記事</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5" data-stagger-children>
          {blogs.contents.map((post) => (
            <BlogCard
              slug={post.id}
              title={post.title}
              eyecatch={post.eyecatch?.url}
              publishedAt={post.publishedAt}
              category={post.category}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Channel -->
  <ChannelSection />

  <!-- Recruit -->
  <RecruitSection />
</BaseLayout>
