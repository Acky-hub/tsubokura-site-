---
// Full-screen hero with large typography and particle background
---

<section class="relative h-screen flex items-center justify-center overflow-hidden noise-bg">
  <!-- Particle / Ambient Light Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-silver/5 rounded-full blur-[120px]" data-parallax="0.3"></div>
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 bg-accent/5 rounded-full blur-[100px]" data-parallax="0.2"></div>
    <div class="absolute top-1/2 left-1/2 w-96 h-96 bg-silver/3 rounded-full blur-[150px] -translate-x-1/2 -translate-y-1/2" data-parallax="0.15"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 text-center px-6" id="hero-content">
    <h1 class="hero-name font-serif text-[clamp(2rem,8vw,7rem)] tracking-[0.3em] leading-none text-gradient-metallic mb-6">
      HIDEYUKI<br class="md:hidden" /> TSUBOKURA
    </h1>
    <p class="hero-sub text-[11px] tracking-[0.5em] uppercase text-text-sub opacity-0">
      CEO &nbsp;/&nbsp; Entrepreneur &nbsp;/&nbsp; Visionary
    </p>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-0" id="scroll-indicator">
    <span class="text-[9px] tracking-[0.3em] uppercase text-text-sub">Scroll</span>
    <div class="w-[1px] h-8 bg-gradient-to-b from-silver/40 to-transparent animate-bounce"></div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const heroName = document.querySelector('.hero-name');
    const heroSub = document.querySelector('.hero-sub');
    const scrollIndicator = document.getElementById('scroll-indicator');

    if (!heroName) return;

    // Split text into spans for stagger animation
    const text = heroName.innerHTML;
    let inTag = false;
    let result = '';

    for (let i = 0; i < text.length; i++) {
      if (text[i] === '<') { inTag = true; result += text[i]; continue; }
      if (text[i] === '>') { inTag = false; result += text[i]; continue; }
      if (inTag) { result += text[i]; continue; }
      if (text[i] === ' ') { result += ' '; continue; }
      result += `<span class="hero-char" style="display:inline-block;opacity:0;transform:translateY(30px)">${text[i]}</span>`;
    }
    heroName.innerHTML = result;

    const charEls = heroName.querySelectorAll('.hero-char');

    // Stagger fade-in
    gsap.to(charEls, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.04,
      ease: 'power3.out',
      delay: 0.3,
    });

    // Subtitle fade-in
    gsap.to(heroSub, {
      opacity: 1,
      duration: 1,
      delay: 1.2,
      ease: 'power2.out',
    });

    // Scroll indicator fade-in
    gsap.to(scrollIndicator, {
      opacity: 1,
      duration: 1,
      delay: 1.8,
      ease: 'power2.out',
    });

    // Parallax on scroll: hero content moves up
    gsap.to('#hero-content', {
      y: -150,
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero-content',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });
  });
</script>
