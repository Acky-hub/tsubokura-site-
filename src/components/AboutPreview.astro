---
interface Props {
  image?: string;
}

const { image = '/images/hero.jpg' } = Astro.props;
---

<section class="py-24 md:py-40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
      <!-- Image with parallax -->
      <div class="relative overflow-hidden gsap-fade-left">
        <div data-parallax="0.15">
          <img
            src={image}
            alt="坪倉秀行"
            class="w-full aspect-[3/4] object-cover mix-blend-luminosity hover:mix-blend-normal transition-all duration-700"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="gsap-fade-right">
        <p class="section-label mb-6">About</p>
        <h2 class="heading-serif text-3xl md:text-4xl mb-6">
          坪倉 秀行
        </h2>
        <p class="text-sm text-text-sub leading-loose mb-8">
          岡山を拠点に飲食・美容・ウェルネス・食品ブランドの4業種5事業を展開する経営者。
          「つくる"いい一日"」をコンセプトに、人々の日常に価値ある体験を提供し続ける。
        </p>
        <a href="/about" class="btn-luxury btn-luxury-outline" data-cursor-hover>
          Read More
        </a>
      </div>
    </div>
  </div>
</section>
