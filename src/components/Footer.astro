---
import SnsLinks from './SnsLinks.astro';
---

<footer class="py-16 border-t border-border">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Left: Logo + Email -->
      <div class="text-center md:text-left">
        <span class="font-serif text-xl text-gradient-metallic tracking-wider">HT</span>
        <p class="text-[11px] text-text-sub mt-2 tracking-wider">
          info@tsubokurahideyuki.com
        </p>
      </div>

      <!-- Center: SNS -->
      <SnsLinks />

      <!-- Right: Copyright -->
      <p class="text-[10px] text-text-sub/50 tracking-wider">
        &copy; 2026 Hideyuki Tsubokura
      </p>
    </div>
  </div>
</footer>
