---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Business', href: '/#business' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 md:px-10 flex items-center justify-between h-16">
    <!-- HT Monogram -->
    <a href="/" class="text-gradient-metallic font-serif text-2xl font-semibold tracking-wider" data-cursor-hover>
      HT
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-10">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-[11px] uppercase tracking-[0.25em] text-text-sub hover:text-accent transition-colors duration-300"
          data-cursor-hover
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Menu Toggle -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-[5px] w-6" data-cursor-hover aria-label="Menu">
      <span class="menu-line block h-[1px] w-full bg-text transition-all duration-300"></span>
      <span class="menu-line block h-[1px] w-full bg-text transition-all duration-300"></span>
    </button>
  </div>
</header>

<!-- Fullscreen Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-bg/95 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500">
  <nav class="flex flex-col items-center gap-8">
    {navItems.map((item, i) => (
      <a
        href={item.href}
        class="mobile-nav-item text-3xl font-serif tracking-wider text-text-sub hover:text-accent transition-colors duration-300 opacity-0 translate-y-4"
        style={`transition-delay: ${i * 0.08}s`}
        data-cursor-hover
      >
        {item.label}
      </a>
    ))}
  </nav>
</div>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuLines = menuToggle?.querySelectorAll('.menu-line');
    const mobileNavItems = mobileMenu?.querySelectorAll('.mobile-nav-item');
    let menuOpen = false;

    // Scroll-based header styling
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        header?.classList.add('bg-bg/85', 'backdrop-blur-xl');
      } else {
        header?.classList.remove('bg-bg/85', 'backdrop-blur-xl');
      }
    });

    // Mobile menu toggle
    menuToggle?.addEventListener('click', () => {
      menuOpen = !menuOpen;
      if (menuOpen) {
        mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
        menuLines?.[0]?.classList.add('rotate-45', 'translate-y-[3px]');
        menuLines?.[1]?.classList.add('-rotate-45', '-translate-y-[3px]');
        mobileNavItems?.forEach((item) => {
          item.classList.remove('opacity-0', 'translate-y-4');
          item.classList.add('opacity-100', 'translate-y-0');
        });
      } else {
        mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
        menuLines?.[0]?.classList.remove('rotate-45', 'translate-y-[3px]');
        menuLines?.[1]?.classList.remove('-rotate-45', '-translate-y-[3px]');
        mobileNavItems?.forEach((item) => {
          item.classList.add('opacity-0', 'translate-y-4');
          item.classList.remove('opacity-100', 'translate-y-0');
        });
      }
    });

    // Close menu on nav click
    mobileNavItems?.forEach((item) => {
      item.addEventListener('click', () => {
        menuToggle?.click();
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeader);
  } else {
    initHeader();
  }
</script>
