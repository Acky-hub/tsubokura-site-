---
// src/components/Header.astro
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Business', href: '/business' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---
<header
  id="site-header"
  class:list={[
    'fixed top-0 w-full z-50 transition-all duration-300',
    isHome ? 'bg-gradient-to-b from-bg/60 to-transparent' : 'bg-bg/80 backdrop-blur-md border-b border-border',
  ]}
>
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-text hover:no-underline tracking-wider">
      TSUBOKURA
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-xs tracking-[0.15em] uppercase transition-colors hover:no-underline',
              currentPath === item.href ? 'text-accent' : 'text-text-sub hover:text-text',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden text-text p-2"
      aria-label="メニューを開く"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg/95 backdrop-blur-md border-t border-border">
    <ul class="px-6 py-6 space-y-5">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block text-sm tracking-[0.15em] uppercase',
              currentPath === item.href ? 'text-accent' : 'text-text-sub',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Header background on scroll (home page only)
  const header = document.getElementById('site-header');
  if (header && !header.classList.contains('bg-bg/80')) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        header.style.background = 'rgba(10,10,10,0.85)';
        header.style.backdropFilter = 'blur(12px)';
        header.style.borderBottom = '1px solid rgba(42,42,42,0.5)';
      } else {
        header.style.background = '';
        header.style.backdropFilter = '';
        header.style.borderBottom = '';
      }
    });
  }
</script>
