---
interface Props {
  name: string;
  description: string;
  category?: string;
  image?: string;
  url?: string;
  index: number;
}

const { name, description, category, image, url, index } = Astro.props;
const isEven = index % 2 === 0;
const animClass = isEven ? 'gsap-fade-left' : 'gsap-fade-right';
const hasImage = image && !image.includes('unsplash');
---

<div class={`grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-0 items-stretch ${animClass}`}>
  <!-- Image Side -->
  <div class={`relative overflow-hidden aspect-[16/10] md:aspect-auto md:min-h-[500px] ${!isEven ? 'md:order-2' : ''}`}>
    {hasImage ? (
      <img
        src={image}
        alt={`${name} — 坪倉秀行が運営する事業｜株式会社ヴィクトワール`}
        class="w-full h-full object-cover img-zoom"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-bg-section to-bg-card flex items-center justify-center">
        <span class="font-serif text-4xl md:text-5xl text-outline tracking-wider">
          {name}
        </span>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-bg/60 to-transparent hover:opacity-40 transition-opacity duration-500"></div>
  </div>

  <!-- Text Side -->
  <div class={`flex flex-col justify-center p-8 md:p-16 ${!isEven ? 'md:order-1' : ''}`}>
    {category && (
      <p class="section-label mb-4">{category}</p>
    )}
    <h3 class="heading-serif text-2xl md:text-4xl mb-4">{name}</h3>
    <p class="text-sm text-text-sub leading-loose mb-8">{description}</p>
    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[11px] tracking-[0.2em] uppercase text-accent hover:text-silver-light transition-colors duration-300 group"
        data-cursor-hover
      >
        View More
        <span class="block w-8 h-[1px] bg-accent group-hover:w-12 transition-all duration-300"></span>
      </a>
    )}
  </div>
</div>
